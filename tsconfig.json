{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "noImplicitAny": false,
    "paths": {
      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
