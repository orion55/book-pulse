{
  "name": "book-pulse",
  "description": "Программа для отслеживание новых книг",
  "version": "1.1.0",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/orion55/book-pulse.git"
  },
  "keywords": [
    "синхронизация",
    "книги"
  ],
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "generate-clients": "npx prisma generate",
    "lint": "npx eslint .",
    "format": "npx prettier --write .",
    "docker": "docker compose down --remove-orphans && docker compose up --build --force-recreate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/ansi-colors": "^3.2.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.43",
    "@vercel/ncc": "^0.44.0",
    "cpy-cli": "^5.0.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "3.8.5",
    "prisma": "^6.19.3",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "ansi-colors": "^4.1.3",
    "cfonts": "^3.3.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "lodash": "^4.18.1",
    "telegraf": "^4.16.3",
    "winston": "^3.19.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
